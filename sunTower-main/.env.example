SPRING_PROFILES_ACTIVE=mysql

# Examples:
# SPRING_PROFILES_ACTIVE=mysql
# SPRING_PROFILES_ACTIVE=mysql,local-nooauth

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/estate
SPRING_DATASOURCE_USERNAME=your_mysql_username
SPRING_DATASOURCE_PASSWORD=your_mysql_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@example.com
SPRING_MAIL_PASSWORD=your_app_password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_SMTP_SSL_TRUST=smtp.gmail.com

BUILDING_IMAGE_UPLOAD_DIR=./src/main/resources/static/images/building_img
PLANNING_MAP_IMAGE_UPLOAD_DIR=./src/main/resources/static/images/planning_map_img

GOONG_API_KEY=your_goong_api_key

JWT_SECRET=replace_with_a_secure_secret_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d
JWT_COOKIE_SECURE=false

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CLIENT_SCOPE=openid,profile,email

PAYMENT_QR_BANK_BIN=your_bank_bin
PAYMENT_QR_ACCOUNT_NO=your_account_number
PAYMENT_QR_ACCOUNT_NAME=your_account_name
